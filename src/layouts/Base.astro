---
import "../styles/global.css";
import { SITE } from "../data/siteConfig";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title
  ? `${title} · ${SITE.name}`
  : `${SITE.name} — ${SITE.tagline}`;
const pageDesc = description ?? SITE.description;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${baseUrl}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hubot+Sans:ital,wdth,wght@0,75..125,200..900;1,75..125,200..900&family=Geist:wght@300..800&family=Geist+Mono:wght@300..700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href={href("/favicon.ico")} sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={href("/web-app-icon-192.png")}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href={href("/web-app-icon-512.png")}
    />
    <link rel="apple-touch-icon" href={href("/apple-touch-icon.png")} />
    <link rel="manifest" href={href("/site.webmanifest")} />
    <meta name="theme-color" content="#0a0b0e" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={href("/web-app-icon-512.png")} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
