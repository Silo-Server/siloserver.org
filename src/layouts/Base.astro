---
import "../styles/global.css";
import { SITE } from "../data/siteConfig";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title
  ? `${title} · ${SITE.name}`
  : `${SITE.name} — ${SITE.tagline}`;
const pageDesc = description ?? SITE.description;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${baseUrl}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <!-- Theme: set before paint to avoid a flash. Shares the
         `starlight-theme` key so the choice carries into /docs. -->
    <script is:inline>
      (function () {
        try {
          var KEY = "starlight-theme";
          var el = document.documentElement;
          var c = localStorage.getItem(KEY);
          var m = c === "light" || c === "dark" || c === "auto" ? c : "auto";
          var d =
            m === "dark" ||
            (m !== "light" &&
              matchMedia("(prefers-color-scheme: dark)").matches);
          el.setAttribute("data-theme", d ? "dark" : "light");
          el.setAttribute("data-mode", m);
        } catch (e) {}
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders:opsz,wght@10..72,300..900&family=Archivo:ital,wdth,wght@0,62..125,100..900;1,62..125,100..900&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href={href("/favicon.ico")} sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={href("/web-app-icon-192.png")}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href={href("/web-app-icon-512.png")}
    />
    <link rel="apple-touch-icon" href={href("/apple-touch-icon.png")} />
    <link rel="manifest" href={href("/site.webmanifest")} />
    <meta name="theme-color" content="#f1ecdf" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={href("/web-app-icon-512.png")} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <script is:inline>
      (function () {
        var KEY = "starlight-theme";
        var r = document.documentElement;
        var b = document.getElementById("themeToggle");
        if (!b) return;
        var mq = matchMedia("(prefers-color-scheme: dark)");
        function stored() {
          try {
            return localStorage.getItem(KEY);
          } catch (e) {
            return null;
          }
        }
        function mode(v) {
          return v === "light" || v === "dark" || v === "auto" ? v : "auto";
        }
        function effective(m) {
          return m === "dark" || m === "light"
            ? m
            : mq.matches
              ? "dark"
              : "light";
        }
        function apply() {
          var m = mode(stored());
          r.setAttribute("data-mode", m);
          r.setAttribute("data-theme", effective(m));
        }
        // Cycle: auto (follow system) → light → dark → auto.
        // Each state has its own icon: monitor / sun / moon.
        b.addEventListener("click", function () {
          var c = mode(stored());
          var n = c === "auto" ? "light" : c === "light" ? "dark" : "auto";
          try {
            localStorage.setItem(KEY, n);
          } catch (e) {}
          apply();
          b.setAttribute(
            "aria-label",
            "Theme: " + (n === "auto" ? "auto (follow system)" : n),
          );
        });
        mq.addEventListener("change", function () {
          if (mode(stored()) === "auto") apply();
        });
      })();
    </script>
  </body>
</html>
