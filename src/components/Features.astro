---
import { features } from "../data/features";
import { REPOS, repoUrl } from "../data/siteConfig";
---

<section class="section section--features" id="features">
  <div class="container">
    <header class="section__head section__head--split">
      <div>
        <p class="section__eyebrow">
          <span class="hatch ink-red" aria-hidden="true"></span>
          <span>sec. 01 — features</span>
        </p>
        <h2 class="section__title">
          The basics, <br />
          <span class="ink-blue">done well</span>.
        </h2>
      </div>
      <p class="section__lede">
        Fast playback, clean profiles, useful discovery, and a path to grow
        past one machine.
      </p>
    </header>

    <div class="feature-grid">
      {
        features.map((f) => (
          <article class="feature">
            <div class="feature__id">{f.id}</div>
            <h3 class="feature__title">{f.title}</h3>
            <p class="feature__body">{f.body}</p>
            <ul class="feature__chips">
              {f.chips.map((c) => {
                if (c.repo && c.repo in REPOS) {
                  const repoName = REPOS[c.repo as keyof typeof REPOS];
                  return (
                    <li>
                      <a href={repoUrl(repoName)}>{c.label} ↗</a>
                    </li>
                  );
                }
                return <li>{c.label}</li>;
              })}
            </ul>
          </article>
        ))
      }
      {/* Fill the trailing cells of the 3-col row so the grid's ruling
          background (var(--ink)) isn't exposed as a bright block. */}
      {
        Array.from({ length: (3 - (features.length % 3)) % 3 }).map(() => (
          <span class="feature feature--filler" aria-hidden="true" />
        ))
      }
    </div>
  </div>
</section>
