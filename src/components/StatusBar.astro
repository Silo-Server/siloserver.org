---
import SiloBars from "./SiloBars.astro";
import { SITE, REPOS, repoUrl } from "../data/siteConfig";
---

<header class="statusbar" aria-label="Project status">
  <div class="statusbar__inner">
    <span class="statusbar__cell statusbar__cell--brand">
      <SiloBars />
      <span class="statusbar__wordmark">{SITE.name}</span>
    </span>
    <span class="statusbar__cell statusbar__cell--mono">
      <span class="statusbar__dot statusbar__dot--green"></span>
      {SITE.status}
    </span>
    <span class="statusbar__spacer"></span>
    <nav class="statusbar__nav" aria-label="Primary">
      <a href="#features">features</a>
      <a href="#stack">stack</a>
      <a href="#clients">clients</a>
      <a href="/docs">docs</a>
      <a href={repoUrl(REPOS.server)} class="statusbar__github">github ↗</a>
      <button
        type="button"
        id="themeToggle"
        class="statusbar__theme"
        aria-label="Theme: auto (follow system)"
        title="Cycle theme — auto / light / dark"
      >
        <svg class="sys" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="13" rx="1.5"></rect><path d="M8.5 21h7M12 17.5V21"></path></svg>
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.2"></circle><path d="M12 2.5v2.2M12 19.3v2.2M4.4 4.4l1.6 1.6M18 18l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.4 19.6l1.6-1.6M18 6l1.6-1.6"></path></svg>
        <svg class="moon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 14.8A8.2 8.2 0 0 1 9.2 3.5 7.2 7.2 0 1 0 20.5 14.8z"></path></svg>
      </button>
    </nav>
  </div>
</header>
