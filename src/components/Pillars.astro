---
import { pillars } from "../data/pillars";
---

<section class="section section--infra" id="stack">
  <div class="container">
    <header class="section__head section__head--split">
      <div>
        <p class="section__eyebrow">
          <span class="hatch ink-blue" aria-hidden="true"></span>
          <span>sec. 02 — stack</span>
        </p>
        <h2 class="section__title">
          Simple stack. <br />
          <span class="ink-blue">Room to grow</span>.
        </h2>
      </div>
      <p class="section__lede">
        Go, Postgres, ffmpeg, and gRPC plugins. Small enough for a mini PC;
        flexible enough for a lab full of workers.
      </p>
    </header>

    <div class="pillars">
      {
        pillars.map((p, i) => (
          <article class={`pillar pillar--${p.color}`}>
            <div class="pillar__head">
              <span class="pillar__bar" aria-hidden="true" />
              <span class="pillar__label">{p.label}</span>
              <span class="pillar__index">
                {String(i + 1).padStart(2, "0")}/04
              </span>
            </div>
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__body">{p.body}</p>
            <dl class="pillar__specs">
              {p.specs.map((s) => (
                <div>
                  <dt>{s.label}</dt>
                  <dd>{s.value}</dd>
                </div>
              ))}
            </dl>
          </article>
        ))
      }
    </div>
  </div>
</section>
