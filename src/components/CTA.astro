---
import SiloBars from "./SiloBars.astro";
import { SITE } from "../data/siteConfig";
---

<section class="section section--cta">
  <div class="container container--narrow">
    <div class="cta">
      <SiloBars size="lg" />
      <h2 class="cta__title">
        Try it. <br />Shape it.
      </h2>
      <p class="cta__sub">
        Silo is pre-1.0 and built in the open. Run it, file issues, or send
        patches.
      </p>
      <div class="cta__actions">
        <a href={SITE.github.orgUrl} class="btn btn--primary">
          GitHub <span class="btn__arrow">↗</span>
        </a>
        <a href={SITE.github.readmeUrl} class="btn btn--ghost">
          README <span class="btn__arrow">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>
