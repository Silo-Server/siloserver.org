---
import SiloBars from "./SiloBars.astro";
import { SITE } from "../data/siteConfig";
---

<section class="section section--cta">
  <div class="container container--narrow">
    <div class="cta">
      <SiloBars size="lg" />
      <h2 class="cta__title">
        Run it. Read it. <br />Tell us what's broken.
      </h2>
      <p class="cta__sub">
        A self-hosted media server, building in the open. The best feedback
        you can land is a commit hash, a stack trace, and an opinion.
      </p>
      <div class="cta__actions">
        <a href={SITE.github.orgUrl} class="btn btn--primary">
          github.com/Silo-Server <span class="btn__arrow">↗</span>
        </a>
        <a href={SITE.github.readmeUrl} class="btn btn--ghost">
          read the README <span class="btn__arrow">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>
