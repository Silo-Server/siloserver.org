---
import SiloBars from "./SiloBars.astro";
import Terminal from "./Terminal.astro";
import { SITE } from "../data/siteConfig";

const docsHref = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/docs`;
---

<section class="hero">
  <div class="hero__grain" aria-hidden="true"></div>
  <div class="hero__inner container">
    <div class="hero__col hero__col--lede">
      <div class="hero__stamp" aria-hidden="true">
        <strong>{SITE.status}</strong>
        <small>building in the open</small>
      </div>

      <p class="hero__eyebrow">
        <SiloBars size="sm" />
        <span>self-hosted media · Go · Postgres · ffmpeg</span>
      </p>

      <h1 class="hero__title">
        <span>self-hosted media,</span>
        <span>on your hardware,</span>
        <span class="hero__title--accent">built to grow<em>.</em></span>
      </h1>

      <p class="hero__sub">
        Silo streams your movies, shows, music, books, and audiobooks from
        hardware you control. Start with one box. Add workers when you need
        them. Use Silo apps or Jellyfin-compatible clients.
      </p>

      <div class="hero__actions">
        <a href={SITE.github.readmeUrl} class="btn btn--primary">
          <span class="btn__cmd">$</span>
          <span>docker compose up -d</span>
        </a>
        <a href={docsHref} class="btn btn--ghost">
          docs <span class="btn__arrow">→</span>
        </a>
        <a
          href={`${SITE.github.orgUrl}/silo-server`}
          class="btn btn--ghost"
        >
          source <span class="btn__arrow">↗</span>
        </a>
      </div>

      <ul class="hero__meta">
        <li>
          <span class="hero__meta-label">backend</span>
          <span class="hero__meta-value">Go</span>
        </li>
        <li>
          <span class="hero__meta-label">store</span>
          <span class="hero__meta-value">Postgres + pgvector</span>
        </li>
        <li>
          <span class="hero__meta-label">playback</span>
          <span class="hero__meta-value">ffmpeg · hardware accel</span>
        </li>
        <li>
          <span class="hero__meta-label">clients</span>
          <span class="hero__meta-value">web · native · Jellyfin</span>
        </li>
      </ul>
    </div>

    <div class="hero__col hero__col--demo">
      <figure class="hero__fig">
        <Terminal />
        <figcaption class="hero__figcap">
          <strong>fig. 01</strong>
          <span>first boot — one box</span>
        </figcaption>
      </figure>
    </div>
  </div>

  <div class="hero__rule" aria-hidden="true">
    <SiloBars size="row" />
    <span class="hero__rule-line"></span>
    <span class="hero__rule-text">features · stack · clients</span>
    <span class="hero__rule-line"></span>
  </div>
</section>
