---
import SiloBars from "./SiloBars.astro";
import { SITE, REPOS, repoUrl } from "../data/siteConfig";

const docsHref = `${import.meta.env.BASE_URL.replace(/\/$/, "")}/docs`;
---

<footer class="titleblock" aria-label="Footer">
  <div class="titleblock__inner">
    <div class="titleblock__cell">
      <span class="titleblock__brand">
        <SiloBars size="sm" />
        {SITE.name}
      </span>
    </div>
    <div class="titleblock__cell">
      <span class="titleblock__label">links</span>
      <span class="titleblock__value">
        <a href={docsHref}>docs</a>
        <a href={repoUrl(REPOS.server)}>source</a>
        <a href={SITE.github.orgUrl}>org</a>
      </span>
    </div>
    <div class="titleblock__cell">
      <span class="titleblock__label">license</span>
      <span class="titleblock__value">{SITE.license}</span>
    </div>
    <div class="titleblock__cell">
      <span class="titleblock__label">status</span>
      <span class="titleblock__value">{SITE.status}</span>
    </div>
  </div>
</footer>
